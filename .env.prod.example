# Production environment — copy to .env.prod and fill in real values.
# NEVER commit .env.prod to git.

# Postgres
POSTGRES_USER=payload
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=payload_db

# Anthropic
ANTHROPIC_API_KEY=

# Payload CMS
PAYLOAD_SECRET=CHANGE_ME_MIN_32_CHARS

# Next.js
NEXT_PUBLIC_SERVER_URL=https://dovetailworks.io

# Cal.com
NEXT_PUBLIC_CAL_LINK=brian-francoeur-4isdxl/lead-flow-breakdown

# Email (production SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=noreply@dovetailworks.io

# Hetzner Object Storage (S3-compatible — for off-site backups)
HETZNER_STORAGE_ENDPOINT=https://nbg1.your-objectstorage.com
HETZNER_STORAGE_BUCKET=dovetail-backups
HETZNER_STORAGE_ACCESS_KEY=
HETZNER_STORAGE_SECRET_KEY=

# Agent guardrails
AGENTS_ENABLED=true

# Slack
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_WEBHOOK_URL=
SLACK_NOTIFICATION_CHANNEL=#crm-notifications

# Cron secret — protects the /api/crm/reminders endpoint
CRON_SECRET=CHANGE_ME_RANDOM_32_CHARS

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
