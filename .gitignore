# dependencies
node_modules/

# Next.js
.next/
out/

# Payload
src/payload-types.ts
src/generated-schema.graphql
src/app/(payload)/admin/importMap.js

# build output
dist/
build/

# env — never commit secrets
.env
.env.local
.env.production
.env.prod

# uploads
public/media/

# SSL certs — generate locally, never commit
nginx/certs/*.pem
nginx/certs/*.crt
nginx/certs/*.key

# Claude Code local settings
.claude/

# Vault data — never commit vault storage
vault/data/

# Agent kill switch — created at runtime, never committed
.agent-lock

# Database backups — kept locally, synced off-site manually for now
backups/

# misc
*.log
.DS_Store
coverage/
